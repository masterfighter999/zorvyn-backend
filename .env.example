# ── Aiven PostgreSQL ──
DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname?ssl=require

# ── Aiven Valkey (Redis-compatible) ──
REDIS_URL=rediss://default:your-password-here@valkey-27b3e016-masterfighter999-ad40.a.aivencloud.com:16404

# ── Aiven Kafka ──
KAFKA_BOOTSTRAP_SERVERS=host:16405
KAFKA_SSL_CAFILE=ca.pem
KAFKA_SSL_CERTFILE=service.cert
KAFKA_SSL_KEYFILE=service.key

# ── JWT (required – no default) ──
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── App ──
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
